      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Claude bridge provides no verifiable command, path, or tool input; to avoid false approval, it must be rejected. Please upgrade the bridge and try again."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Claude bridge 未提供可核对的命令、路径或工具输入；为避免误批准，只能拒绝。请升级 bridge 后重试。"
          }
        }
      }
    },
    "ui.claude_code_headless_currently_does_not_provide_full": {
      "comment": "User-facing UI text. Keep this stable semantic key; never use catalog values for protocol fields or log parsing.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Claude Code headless currently does not provide full usage percentage; after receiving the official rate-limit event, it will display the real window and reset time, and will not estimate or crawl web page data."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Claude Code headless 当前不提供完整使用百分比；收到官方 rate-limit 事件后会显示真实窗口与重置时间，不会估算或抓取网页数据。"
          }
        }
      }
    },
