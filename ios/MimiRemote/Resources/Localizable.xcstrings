    "ui.this_will_delete_the_corresponding_git_checkout_the": {
      "comment": "User-facing UI text. Keep this stable semantic key; never use catalog values for protocol fields or log parsing.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will delete the corresponding Git checkout. The client will not send force; agentd will still do a final check on the current candidate and all blockers."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会删除对应 Git checkout。客户端不会发送 force；agentd 仍会对当前候选和所有 blocker 做最终检查。"
          }
        }
      }
    },
    "ui.this_will_delete_value_s_access_code_from": {
      "comment": "User-facing UI text. Keep this stable semantic key; never use catalog values for protocol fields or log parsing.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will remove %@'s access code from the current device's system keychain and clear the currently connected sessions, messages, and logs in the app. You need to scan the QR code to pair again when connecting again."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会从当前设备的系统钥匙串（Keychain）删除%@的访问码，并清除 App 中当前连接的会话、消息和日志。再次连接时需要重新扫码配对。"
          }
        }
      }
    },
    "ui.this_will_delete_value_s_connection_profile_and": {
      "comment": "User-facing UI text. Keep this stable semantic key; never use catalog values for protocol fields or log parsing.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will delete the connection profile and system keychain access code for \"%@\" from the current device. You need to scan the QR code to pair again when connecting again; the current Mac connection will not be affected."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会从当前设备删除“%@”的连接档案和系统钥匙串（Keychain）访问码。再次连接时需要重新扫码配对；当前 Mac 连接不会受影响。"
          }
        }
      }
    },
