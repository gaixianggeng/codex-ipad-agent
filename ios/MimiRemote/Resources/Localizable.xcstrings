    "ui.clean_candidates_will_first_be_previewed_according_to": {
      "comment": "User-facing UI text. Keep this stable semantic key; never use catalog values for protocol fields or log parsing.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Clean candidates\" will first be previewed according to the server's fixed retention policy, and only candidates without blockers can be confirmed for deletion; \"Clean lost registrations\" only removes non-existent registry records."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“清理候选”会先按服务端固定保留策略预览，只有无 blocker 的候选可确认删除；“清理丢失登记”只移除不存在的 registry 记录。"
          }
