    "ui.a_preflighted_git_testflight_push_will_be_executed": {
      "comment": "User-facing UI text. Keep this stable semantic key; never use catalog values for protocol fields or log parsing.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A preflighted git testflight-push will be executed on the host. It checks the remote commit and uses the host's local signature and App Store Connect configuration to complete the internal release."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将在主机执行已通过预检的 git testflight-push。它会核对远端 commit，并使用主机本地的签名与 App Store Connect 配置完成内部发布。"
          }
        }
      }
    },
