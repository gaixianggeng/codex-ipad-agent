# 复制到 ~/.config/ios-testflight/mimi/secrets.env，并 chmod 600。
APP_STORE_CONNECT_API_KEY_ID=YOUR_KEY_ID
APP_STORE_CONNECT_API_ISSUER_ID=YOUR_ISSUER_ID
APP_STORE_CONNECT_API_KEY_PATH=/absolute/path/AuthKey_KEY_ID.p8

IOS_DISTRIBUTION_CERTIFICATE_PATH=/absolute/path/distribution.p12
IOS_DISTRIBUTION_CERTIFICATE_PASSWORD_FILE=/absolute/path/p12-password.txt
IOS_KEYCHAIN_PASSWORD_FILE=/absolute/path/temp-keychain-password.txt
